# ── LLM Provider ──────────────────────────────────────────────────────────────
# CrewAI uses OpenAI by default. Swap in any compatible provider below.

OPENAI_API_KEY=sk-...

# Optional: use a different model (default is gpt-4o)
# OPENAI_MODEL_NAME=gpt-4o-mini

# Optional: use Anthropic Claude instead
# ANTHROPIC_API_KEY=sk-ant-...
# (set model in crew.py: llm="claude-opus-4-6" or "claude-sonnet-4-6")

# ── Search Tool ───────────────────────────────────────────────────────────────
# Get a free API key at https://serper.dev (2,500 free searches/month)
SERPER_API_KEY=your-serper-key-here
